# B.L.A.S.T Integrations Configuration

# ----------------------------------------
# 1. AI Assistant (OpenAI / Gemini)
# ----------------------------------------
OPENAI_API_KEY="your_openai_api_key_here"
# If using Gemini instead of OpenAI as per previous project structure
GEMINI_API_KEY="your_gemini_api_key_here"

# ----------------------------------------
# 2. Supabase (Database & Auth & Realtime)
# ----------------------------------------
SUPABASE_URL="your_supabase_project_url"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# ----------------------------------------
# 3. OAuth Providers (Google/GitHub)
# ----------------------------------------
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

# ----------------------------------------
# 4. Storage & Media (Cloudinary / UploadThing)
# ----------------------------------------
CLOUDINARY_URL="your_cloudinary_url"
UPLOADTHING_SECRET="your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# ----------------------------------------
# 5. Environment
# ----------------------------------------
APP_URL="http://localhost:3000"
NODE_ENV="development"
